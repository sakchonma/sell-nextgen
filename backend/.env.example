# ------------------------------------------------------------------------------
# NEXTGEN Backend Environment Variables Template
# ------------------------------------------------------------------------------

# Application Port
PORT=5001

# Comma-separated frontend origins allowed by CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3001

# Environment (development | production | test)
NODE_ENV=development

# Authentication
# Required in production. Use a strong random value with at least 32 characters.
JWT_SECRET=replace_with_a_strong_random_secret_at_least_32_chars

# Cookie security. In production COOKIE_SECURE defaults to true.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Development-only DB fallback controls
# USE_MOCK_DB=true forces in-memory DB. Do not enable in production.
USE_MOCK_DB=false

# Quick account swapper should remain disabled in production unless explicitly allowed for a controlled test.
ALLOW_QUICK_SWAP=false

# ALLOW_MEMORY_DB defaults to true outside production and false in production.
# Keep this false in production so the server fails fast instead of writing volatile data.
ALLOW_MEMORY_DB=false

# MongoDB Connection String & Database Name
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=sell_nextgen_db

# Gemini AI API Key (Required for AI Coach & AI Logger modules)
# Get your API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
